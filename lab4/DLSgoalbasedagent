alphabetTree = {
    'A': ['B', 'C'],
    'B': ['D', 'E'],
    'C': ['F', 'G'],
    'D': ['H', 'I'],
    'E': ['J', 'K'],
    'F': ['L', 'M'],
    'G': ['N', 'O'],
    'H': ['P', 'Q'],
    'I': ['R', 'S'],
    'J': ['T', 'U'],
    'K': ['V', 'W'],
    'L': ['X', 'Y'],
    'M': ['Z', None],
    'N': [None, None],
    'O': [None, None],
    'P': [None, None],
    'Q': [None, None],
    'R': [None, None],
    'S': [None, None],
    'T': [None, None],
    'U': [None, None],
    'V': [None, None],
    'W': [None, None],
    'X': [None, None],
    'Y': [None, None],
    'Z': [None, None]
}

class Environment:
    def __init__(self, tree):
        self.tree = tree

    def get_neighbours(self, node):
        return self.tree[node]

    def get_percept(self, node):
        return node


class DlsAgent:
    def __init__(self, target, limit):
        self.goal = target
        self.limit = limit

    def is_goal(self, percept):
        return percept == self.goal

    def DLSact(self, start, env):
        visited = []
        stack = [(start, 0)]  # (node, current_depth)

        while stack:
            node, depth = stack.pop()

            if node in visited:
                continue
            visited.append(node)

            print(f"DLS Visiting: {node} (depth {depth})")

            if self.is_goal(node):
                return f"Found '{node}' at depth {depth}"

            # Only expand if we haven't hit the depth limit
            if depth < self.limit:
                for neighbour in env.get_neighbours(node):
                    if neighbour is not None and neighbour not in visited:
                        stack.append((neighbour, depth + 1))

        return f"Not found within depth limit of {self.limit}"


def runAgent():
    env = Environment(alphabetTree)
    target = input("Enter the node to find: ").upper()
    limit = int(input("Enter the depth limit: "))
    agent = DlsAgent(target, limit)

    start = env.get_percept('A')
    result = agent.DLSact(start, env)
    print(result)

runAgent()